# =============================================================================
# .gitignore — bcc (Blitzy C Compiler)
# Standard Rust/Cargo ignores plus project-specific exclusions
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo build output
# -----------------------------------------------------------------------------
/target

# Rust source backup files generated by rustfmt or editors
**/*.rs.bk

# Windows debug symbol files (included for cross-platform completeness)
*.pdb

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------

# JetBrains IDEs (CLion, IntelliJ IDEA, RustRover)
.idea/

# Visual Studio Code
.vscode/

# Vim swap files
*.swp
*.swo

# Emacs backup and auto-save files
*~
\#*\#
.#*

# macOS Finder metadata
.DS_Store

# Windows thumbnail cache
Thumbs.db

# -----------------------------------------------------------------------------
# Validation source trees
# These are fetched at validation time by the test harness and must never be
# committed to the repository. See tests/validation/ for the fetching logic.
# -----------------------------------------------------------------------------
validation/sqlite/
validation/lua/
validation/zlib/
validation/redis/

# -----------------------------------------------------------------------------
# Test output and temporary artifacts
# -----------------------------------------------------------------------------

# Temporary files generated during compilation or testing
*.tmp

# Ad-hoc test files created by Blitzy agents during validation
blitzy_adhoc_test_*

# Object files and ELF binaries produced during integration testing
*.o
*.elf

# Core dumps
core
core.*

# Profiling data
perf.data
perf.data.*

# Coverage artifacts
*.gcda
*.gcno
*.gcov
lcov.info
tarpaulin-report.html

# -----------------------------------------------------------------------------
# NOTE: Cargo.lock is intentionally NOT ignored.
# This is a binary project (not a library), so Cargo.lock should be committed
# to ensure reproducible builds. See: https://doc.rust-lang.org/cargo/faq.html
# -----------------------------------------------------------------------------
